static const float PI = 3.14159265359;
static const float TAU = 6.283185307;


#ifdef SPREAD_TEX
#define BLUR_SPREAD float2 spread = _Spread * tex2D(_SpreadTex, TRANSFORM_TEX(i.uv, _SpreadTex)).rg;
#else
#define BLUR_SPREAD float2 spread = _Spread;
#endif

#define SAMPLE_BLUR(sampler, uv, iterations, startOffset, spread, output, plerp) \
    half angleStep = TAU / iterations; \
    UNITY_LOOP \
    for (int n = 0; n < iterations; n++) { \
        float angle = angleStep * n; \
        float2 samplePattern = lerp(float2(-cos(angle), sin(angle)), POISSON2D_SAMPLES[startOffset + n] * 2 - 1, plerp); \
        output += tex2D(sampler, uv + samplePattern * spread); \
    }

#endif
